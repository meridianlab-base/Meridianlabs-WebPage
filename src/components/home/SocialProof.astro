---
// Logo-style name cards — replace with real client logos when available
const logos = ["VORTEX", "ORBIT", "NORDIC", "AXIOM", "MERIDIAN"];
---

<section class="py-section-padding-v px-gutter max-w-container-max mx-auto">
  <p
    class="font-label-mono text-label-mono text-on-surface-variant uppercase text-center mb-stack-lg tracking-widest"
  >
    Trusted by founders and growing brands
  </p>
  <div class="grid grid-cols-2 md:grid-cols-5 gap-card-gap">
    {
      logos.map((name) => (
        <div class="h-24 flex items-center justify-center border border-outline-variant p-4 opacity-50 grayscale hover:opacity-100 hover:grayscale-0 hover:border-primary-fixed transition-all duration-300">
          <span class="font-display-lg text-headline-sm tracking-tighter text-primary">
            {name}
          </span>
        </div>
      ))
    }
  </div>
</section>
