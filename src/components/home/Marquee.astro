---
const items = [
  "Website Build",
  "App Development",
  "Rework & Redesign",
  "UI/UX",
  "Portfolio Projects",
];
// Duplicate the list so the -50% keyframe loops seamlessly
const loop = [...items, ...items];
---

<div class="border-y border-outline-variant py-6 bg-surface-card overflow-hidden whitespace-nowrap">
  <div class="inline-block animate-marquee">
    {
      loop.map((item) => (
        <span class="font-label-mono text-headline-sm text-primary uppercase whitespace-nowrap mx-6">
          {item} ·
        </span>
      ))
    }
  </div>
</div>
