---
import { buttonVariants } from "@/components/ui/button";

const getList = [
  "Real-world portfolio pieces",
  "1-on-1 Senior Mentorship",
  "Contribution credit on client launches",
  "Official Meridian Labs Certificate",
];
const expectList = [
  "40 hours/week commitment",
  "Foundational tech knowledge",
  "Relentless curiosity",
  "Zero ego. Just work.",
];
---

<section class="py-section-padding-v px-gutter max-w-container-max mx-auto border-t border-outline-variant">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-card-gap lg:gap-16 items-center">
    <!-- Left: content -->
    <div class="order-2 lg:order-1">
      <span class="inline-block bg-primary-fixed text-on-primary-fixed font-label-mono text-label-mono uppercase tracking-widest px-3 py-1 mb-stack-md">
        Internship Program
      </span>
      <h2 class="font-headline-lg text-headline-lg-mobile md:text-headline-lg text-primary mb-stack-md text-balance">
        Currently Accepting Interns.
      </h2>
      <p class="font-body-lg text-body-lg text-on-surface-variant max-w-xl mb-stack-md">
        Our internship program is not about fetching coffee. It's an intensive
        3-month cycle designed to produce portfolio-ready work — you'll skip the
        busywork and dive straight into real production environments.
      </p>
      <p class="font-label-mono text-label-mono text-on-surface-variant uppercase tracking-widest mb-stack-lg">
        Current Opening —
        <span class="text-primary-fixed">Digital Product Intern (Q3 2024)</span>
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-card-gap gap-y-stack-lg mb-stack-lg">
        <div class="flex flex-col gap-5">
          <h3 class="font-label-mono text-label-mono text-primary-fixed uppercase tracking-widest border-b border-outline-variant pb-3">
            The Outcome
          </h3>
          <ul class="flex flex-col gap-4">
            {getList.map((i) => (
              <li class="flex items-start gap-3 font-body-md text-body-md text-on-background">
                <span class="mt-[10px] h-1.5 w-1.5 rounded-full bg-primary-fixed shrink-0"></span>
                <span class="leading-6">{i}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="flex flex-col gap-5">
          <h3 class="font-label-mono text-label-mono text-primary-fixed uppercase tracking-widest border-b border-outline-variant pb-3">
            The Expectations
          </h3>
          <ul class="flex flex-col gap-4">
            {expectList.map((i) => (
              <li class="flex items-start gap-3 font-body-md text-body-md text-on-background">
                <span class="mt-[10px] h-1.5 w-1.5 rounded-full bg-primary-fixed shrink-0"></span>
                <span class="leading-6">{i}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <a href="#apply" class={buttonVariants({ variant: "outline", size: "lg" })}>
        Apply for Internship <span class="material-symbols-outlined">arrow_forward</span>
      </a>
    </div>

    <!-- Right: framed image -->
    <div class="order-1 lg:order-2 group border border-outline-variant p-2 lg:p-3">
      <div class="aspect-[4/5] overflow-hidden">
        <img
          src="https://picsum.photos/seed/internlab/900/1125?grayscale"
          alt="An intern working at a developer workstation"
          class="w-full h-full object-cover grayscale"
        />
      </div>
    </div>
  </div>
</section>
