---
interface Props {
  class?: string;
  href?: string | null;
}
// `href=null` renders a non-link (for footer where wrapping <a> isn't wanted)
import { withBase } from "@/lib/links";
const { class: className = "", href = "/" } = Astro.props;
const Tag = href ? "a" : "div";
---

<Tag
  {...href ? { href: withBase(href) } : {}}
  class={`logo inline-flex items-center gap-3 text-primary-fixed ${className}`}
  aria-label="Meridian Labs"
>
  <!-- Double-chevron mark, recolored to accent, transparent bg -->
  <svg
    viewBox="0 0 100 100"
    class="h-7 w-7 shrink-0"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <g
      stroke="currentColor"
      stroke-width="10"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path class="lm-bottom" d="M10 78 L50 50 L90 78"></path>
      <path class="lm-top" d="M24 40 L50 22 L76 40"></path>
    </g>
  </svg>
  <span class="font-display-lg text-headline-sm tracking-tight leading-none whitespace-nowrap">
    <span class="text-primary">Meridian</span>
    <span class="text-on-surface-variant">Labs</span>
  </span>
</Tag>
