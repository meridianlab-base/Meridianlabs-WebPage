---
import { buttonVariants } from "@/components/ui/button";
import { withBase } from "@/lib/links";

interface Props {
  id: string;
  label: string;
  title: string;
  body: string;
  timeline: string;
  ctaLabel: string;
  ctaIcon: string;
  ctaVariant?: "default" | "outline";
  reverse?: boolean; // image on the left
  imgSeed: string;
  imgRatio?: string; // tailwind aspect class
  band?: boolean; // darker background band
}

const {
  id,
  label,
  title,
  body,
  timeline,
  ctaLabel,
  ctaIcon,
  ctaVariant = "default",
  reverse = false,
  imgSeed,
  imgRatio = "aspect-square",
  band = false,
} = Astro.props;

const textOrder = reverse ? "lg:order-2" : "lg:order-1";
const imgOrder = reverse ? "lg:order-1" : "lg:order-2";
---

<section
  id={id}
  class:list={[
    "py-section-padding-v px-gutter max-w-container-max mx-auto grid grid-cols-1 lg:grid-cols-2 gap-card-gap items-center scroll-mt-24",
    band && "bg-surface-container-lowest border-y border-outline-variant",
  ]}
>
  <div class={`order-2 ${textOrder}`}>
    <span class="font-label-mono text-label-mono text-on-surface-variant border border-outline-variant px-3 py-1 mb-6 inline-block">
      {label}
    </span>
    <h2 class="font-headline-lg text-headline-lg-mobile md:text-headline-lg text-primary mb-stack-md">
      {title}
    </h2>
    <p class="font-body-lg text-body-lg text-on-surface-variant mb-stack-lg">{body}</p>

    <slot />

    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-8">
      <div class="flex flex-col">
        <span class="font-label-mono text-label-mono text-on-surface-variant uppercase">Timeline</span>
        <span class="font-headline-sm text-headline-sm text-primary">{timeline}</span>
      </div>
      <a href={withBase("/contact")} class={buttonVariants({ variant: ctaVariant })}>
        {ctaLabel} <span class="material-symbols-outlined">{ctaIcon}</span>
      </a>
    </div>
  </div>

  <div class={`order-1 ${imgOrder} bg-surface-container border border-outline-variant ${imgRatio} relative group overflow-hidden`}>
    <img
      src={`https://picsum.photos/seed/${imgSeed}/900/900?grayscale`}
      alt={title}
      class="w-full h-full object-cover grayscale opacity-60 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700"
    />
    <div class="absolute inset-0 bg-gradient-to-tr from-background to-transparent opacity-40 pointer-events-none"></div>
  </div>
</section>
