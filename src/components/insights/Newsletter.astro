---
import { SHEET_ENDPOINT } from "@/lib/forms";
---

<section class="py-section-padding-v px-gutter max-w-container-max mx-auto border-t border-outline-variant">
  <div class="bg-primary-fixed p-10 md:p-20 flex flex-col md:flex-row items-center justify-between gap-stack-lg">
    <div class="max-w-md">
      <h2 class="font-headline-lg text-display-lg-mobile md:text-headline-lg text-on-primary-fixed mb-4">
        Get New Posts Straight to Your Inbox.
      </h2>
      <p class="font-body-md text-body-md text-on-primary-fixed/80">
        No spam. Just our most technical insights, once a month.
      </p>
    </div>
    <form
      id="newsletter-form"
      data-endpoint={SHEET_ENDPOINT}
      class="w-full md:w-auto flex flex-col sm:flex-row items-stretch gap-0 border-b-2 border-on-primary-fixed"
    >
      <input
        name="email"
        required
        class="bg-transparent border-none font-headline-sm text-headline-sm text-on-primary-fixed placeholder:text-on-primary-fixed/40 focus:ring-0 focus:outline-none px-0 py-4 min-w-[260px] md:min-w-[300px]"
        placeholder="email@meridianlabs.com"
        type="email"
      />
      <button
        type="submit"
        class="font-button text-button text-on-primary-fixed uppercase tracking-widest flex items-center gap-2 py-4 hover:translate-x-2 transition-transform"
      >
        <span data-label>Subscribe</span>
        <span class="material-symbols-outlined">arrow_right_alt</span>
      </button>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById("newsletter-form") as HTMLFormElement | null;
  if (form) {
    const endpoint = form.dataset.endpoint || "";
    const label = form.querySelector("[data-label]") as HTMLElement | null;
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const input = form.querySelector('input[name="email"]') as HTMLInputElement;
      const email = input.value.trim();
      if (!email) return;
      if (label) label.textContent = "Sending…";
      try {
        await fetch(endpoint, {
          method: "POST",
          mode: "no-cors",
          headers: { "Content-Type": "application/x-www-form-urlencoded" },
          body: new URLSearchParams({ formType: "newsletter", email }),
        });
        form.innerHTML =
          '<p class="font-headline-sm text-headline-sm text-on-primary-fixed py-4">Subscribed. Check your inbox soon.</p>';
      } catch {
        if (label) label.textContent = "Try again";
      }
    });
  }
</script>
